{
  "name": "molecule",
  "type": "module",
  "private": true,
  "description": "Composable, injectable modules for full-stack applications",
  "workspaces": [
    "packages/api/core/*",
    "packages/api/bonds/*/*",
    "packages/api/infrastructure/*",
    "packages/api/resources/*",
    "packages/api/middleware/*",
    "packages/api/utilities/*",
    "packages/api/testing",
    "packages/api/ci/*",
    "packages/app/core/*",
    "packages/app/bonds/*/*",
    "packages/app/infrastructure/*",
    "packages/app/features/*",
    "packages/app/native/*",
    "packages/app/frameworks/*",
    "packages/api/locales/*",
    "packages/app/locales/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "test": "vitest run",
    "test:all": "npm run test --workspaces --if-present",
    "lint": "eslint packages/ --max-warnings 0",
    "lint:fix": "eslint packages/ --fix --max-warnings 0",
    "format": "prettier --write 'packages/**/*.ts' --ignore-path .prettierignore",
    "format:check": "prettier --check 'packages/**/*.ts' --ignore-path .prettierignore",
    "changeset": "changeset",
    "version": "changeset version",
    "check:lockfile": "node scripts/check-lockfile.js",
    "check:peer-deps": "node scripts/check-peer-deps.js",
    "check:feature-jsdocs": "node scripts/check-feature-jsdocs.mjs --check",
    "check:security-workflow": "node scripts/check-security-workflow.js",
    "check:i18n-parity": "node scripts/check-i18n-parity.js --check",
    "sync:lockfile": "node scripts/sync-lockfile.js",
    "release": "npm run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint/js": "10.0.1",
    "@tanstack/table-core": "8.21.3",
    "@tanstack/virtual-core": "3.17.0",
    "@types/node": "25.9.2",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "63.0.2",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "handlebars": "4.7.9",
    "husky": "9.1.7",
    "jimp": "1.6.1",
    "jsdom": "29.1.1",
    "zod": "4.4.3",
    "mjml": "5.3.0",
    "node-cron": "4.2.1",
    "pdf-lib": "1.17.1",
    "pdfkit": "0.18.0",
    "prettier": "3.8.3",
    "sharp": "0.34.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8"
  },
  "license": "Apache-2.0"
}
