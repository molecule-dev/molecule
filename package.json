{
  "name": "molecule",
  "type": "module",
  "private": true,
  "description": "Composable, injectable modules for full-stack applications",
  "workspaces": [
    "packages/api/core/*",
    "packages/api/bonds/*/*",
    "packages/api/infrastructure/*",
    "packages/api/resources/*",
    "packages/api/middleware/*",
    "packages/api/utilities/*",
    "packages/api/testing",
    "packages/api/ci/*",
    "packages/app/core/*",
    "packages/app/bonds/*/*",
    "packages/app/infrastructure/*",
    "packages/app/features/*",
    "packages/app/native/*",
    "packages/app/frameworks/*",
    "packages/api/locales/*",
    "packages/app/locales/*",
    "packages/shared/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "test": "vitest run",
    "test:all": "npm run test --workspaces --if-present",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "format": "prettier --write 'packages/**/*.ts' --ignore-path .prettierignore",
    "format:check": "prettier --check 'packages/**/*.ts' --ignore-path .prettierignore",
    "changeset": "changeset",
    "version": "changeset version",
    "check:lockfile": "node scripts/check-lockfile.js",
    "check:peer-deps": "node scripts/check-peer-deps.js",
    "sync:lockfile": "node scripts/sync-lockfile.js",
    "release": "npm run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@eslint/js": "10.0.1",
    "@tanstack/table-core": "8.21.3",
    "@tanstack/virtual-core": "3.13.23",
    "@types/node": "25.5.0",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.7.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "handlebars": "4.7.9",
    "husky": "9.1.7",
    "jimp": "1.6.0",
    "jsdom": "28.1.0",
    "mjml": "4.18.0",
    "node-cron": "4.2.1",
    "pdf-lib": "1.17.1",
    "pdfkit": "0.18.0",
    "prettier": "3.8.1",
    "sharp": "0.34.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.1.0"
  },
  "license": "Apache-2.0"
}
