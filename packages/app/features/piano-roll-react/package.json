    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@molecule/app-i18n": "1.0.0",
    "@molecule/app-react": "1.0.0",
    "@molecule/app-ui": "1.0.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "jsdom": "27.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
