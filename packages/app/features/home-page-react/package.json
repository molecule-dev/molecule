{
  "name": "@molecule/app-home-page-react",
  "version": "1.0.0",
  "description": "Authenticated home page rendering a personalized greeting (h2 with user name or fallback). Reads auth + i18n; styled via ClassMap.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "home",
    "page",
    "react"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "25.9.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "@molecule/app-auth": "1.0.0",
    "@molecule/app-react": "1.0.0",
    "@molecule/app-ui": "1.0.0",
    "@molecule/app-locales-common": "1.0.0",
    "@types/react": "19.2.17",
    "react": "19.2.7"
  },
  "peerDependencies": {
    "@molecule/app-auth": "^1.0.0",
    "@molecule/app-react": "^1.0.0",
    "@molecule/app-ui": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0"
  }
}
