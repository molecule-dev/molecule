{
  "name": "@molecule/app-storefront-chrome-react",
  "version": "1.0.0",
  "description": "E-commerce storefront wrapping chrome: announcement bar, top nav with cart-count + profile menu, and column-based footer. Extracted from online-store flagship.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "ecommerce",
    "storefront",
    "navbar",
    "footer",
    "react"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@molecule/app-react": "^1.0.0",
    "@molecule/app-ui": "^1.0.0",
    "@molecule/app-ui-react": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-router-dom": "^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@molecule/app-react": "1.0.0",
    "@molecule/app-ui": "1.0.0",
    "@molecule/app-ui-react": "1.0.0",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "react": "19.2.6",
    "react-router-dom": "7.15.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
