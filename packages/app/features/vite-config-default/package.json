{
  "name": "@molecule/app-vite-config-default",
  "version": "1.0.0",
  "description": "Drop-in createDefaultViteConfig() factory used by every flagship app vite.config.ts. Captures react + tailwindcss + VitePWA plugin setup, molecule package pre-bundle exclusion, dev server proxy, env conventions.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "vite",
    "config",
    "default"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "25.5.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "@tailwindcss/vite": "4.1.16",
    "@vitejs/plugin-react": "5.1.4",
    "vite": "7.1.10",
    "vite-plugin-pwa": "1.0.4"
  },
  "peerDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.0.0 || ^5.0.0",
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "vite-plugin-pwa": "^0.20.0 || ^1.0.0"
  }
}
