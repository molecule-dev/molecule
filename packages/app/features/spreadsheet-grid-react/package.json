{
  "name": "@molecule/app-spreadsheet-grid-react",
  "version": "1.0.0",
  "description": "High-performance virtualized spreadsheet cell grid with frozen rows/columns, range selection, copy/paste, and in-cell editing — pairs with @molecule/api-formula-engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "spreadsheet",
    "grid",
    "virtualized",
    "react"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@molecule/app-i18n": "^1.0.0",
    "@molecule/app-react": "^1.0.0",
    "@molecule/app-ui": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@molecule/app-i18n": "1.0.0",
    "@molecule/app-react": "1.0.0",
    "@molecule/app-ui": "1.0.0",
    "@molecule/app-ui-tailwind": "1.0.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
