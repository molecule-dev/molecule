{
  "name": "@molecule/app-feature-image-canvas-react",
  "version": "1.0.0",
  "description": "Canvas2D image-editing surface — accepts an image source, applies a filter chain (brightness, contrast, saturation, hue, sepia, grayscale, blur, sharpen), supports zoom + pan, exports back to data URL",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "image-canvas",
    "image",
    "canvas",
    "filters",
    "photo-editor",
    "react"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@molecule/app-react": "^1.0.0",
    "@molecule/app-ui": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@molecule/app-i18n": "1.0.0",
    "@molecule/app-react": "1.0.0",
    "@molecule/app-ui": "1.0.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "jsdom": "29.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
