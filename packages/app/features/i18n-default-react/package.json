{
  "name": "@molecule/app-i18n-default-react",
  "version": "1.0.0",
  "description": "Default i18n bond setup with 74-language definitions, lazy-loading wrapper, and locale persistence via storage bond. Used by every flagship app \u2014 113 lines of byte-identical wiring across the fleet.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "i18n",
    "default",
    "react"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "25.8.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6",
    "@molecule/app-i18n": "1.0.0",
    "@molecule/app-locales-common": "1.0.0",
    "@molecule/app-storage": "1.0.0"
  },
  "peerDependencies": {
    "@molecule/app-i18n": "^1.0.0",
    "@molecule/app-locales-common": "^1.0.0",
    "@molecule/app-storage": "^1.0.0"
  }
}
