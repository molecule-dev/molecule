{
  "name": "@molecule/app-admin-table-react",
  "version": "1.0.0",
  "description": "Admin-style data table: column-defs, row click navigation, bulk-select, row-action kebab menu, loading skeleton, pagination slot. Generalised from AdminProductsTable / AdminOrdersTable in the online-store flagship.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "admin",
    "table",
    "datatable",
    "react"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@molecule/app-react": "^1.0.0",
    "@molecule/app-ui": "^1.0.0",
    "@molecule/app-ui-react": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@molecule/app-react": "1.0.0",
    "@molecule/app-ui": "1.0.0",
    "@molecule/app-ui-react": "1.0.0",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "react": "19.2.6",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  }
}
