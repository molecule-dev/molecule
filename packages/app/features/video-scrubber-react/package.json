    "@molecule/app-i18n": "1.0.0",
    "@molecule/app-react": "1.0.0",
    "@molecule/app-ui": "1.0.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "jsdom": "29.1.1",
    "react": "19.2.4",
