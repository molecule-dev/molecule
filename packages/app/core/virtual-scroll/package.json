{
  "name": "@molecule/app-virtual-scroll",
  "version": "1.0.0",
  "description": "Virtual scroll core interface for molecule.dev — virtual/infinite scrolling for large lists and grids",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "virtual-scroll",
    "virtualization",
    "infinite-scroll"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@molecule/app-bond": "^1.0.0"
  },
  "devDependencies": {
    "@molecule/app-bond": "1.0.0",
    "@types/node": "25.5.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
