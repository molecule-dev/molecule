{
  "name": "@molecule/api-openapi",
  "version": "1.0.0",
  "description": "OpenAPI 3.1 schema generator + validator + Swagger-UI-compatible JSON output.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "openapi",
    "swagger",
    "schema",
    "validation",
    "zod"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
