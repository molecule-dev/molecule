{
  "name": "@molecule/api-leaderboard",
  "version": "1.0.0",
  "description": "Generic ranked-aggregate engine: record metrics, compute leaderboards over daily/weekly/monthly/all-time windows with rank tie-breaking, scope isolation, and cron rollup.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "leaderboard",
    "ranking",
    "aggregation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "25.5.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "@molecule/api-database": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@molecule/api-database": {
      "optional": true
    }
  }
}
