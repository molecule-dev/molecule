{
  "name": "@molecule/api-export-pptx",
  "version": "1.0.0",
  "description": "PPTX export — convert a deck definition into a downloadable PowerPoint (.pptx) buffer.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "export",
    "pptx"
  ],
  "license": "MIT",
  "dependencies": {
    "pptxgenjs": "4.0.1"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  }
}
