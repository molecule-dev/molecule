{
  "name": "@molecule/api-smtp",
  "version": "1.0.0",
  "description": "Direct SMTP send client — sends mail through a user-supplied SMTP server (distinct from transactional email provider bonds).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "smtp",
    "email",
    "nodemailer"
  ],
  "license": "MIT",
  "dependencies": {
    "nodemailer": "9.0.1"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "@types/nodemailer": "8.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
