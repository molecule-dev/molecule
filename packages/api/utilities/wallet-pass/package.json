{
  "name": "@molecule/api-wallet-pass",
  "version": "1.0.0",
  "description": "Apple Wallet (.pkpass) + Google Wallet pass-object generation — signed manifests, JWT-signed pass classes, and HTTP handlers for ticket delivery.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "wallet-pass",
    "apple-wallet",
    "pkpass",
    "google-wallet",
    "ticket"
  ],
  "license": "MIT",
  "dependencies": {
    "node-forge": "1.4.0"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "@types/node-forge": "1.3.14",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  }
}
