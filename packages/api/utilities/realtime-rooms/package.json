{
  "name": "@molecule/api-realtime-rooms",
  "version": "1.0.0",
  "description": "Realtime rooms abstraction: named pub/sub rooms with membership, capacity, join codes, role-based auth, built atop @molecule/api-realtime.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "realtime",
    "rooms",
    "pubsub",
    "presence"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "25.8.0",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "@molecule/api-database": "^1.0.0",
    "@molecule/api-realtime": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@molecule/api-database": {
      "optional": true
    },
    "@molecule/api-realtime": {
      "optional": true
    }
  }
}
