{
  "name": "@molecule/api-quiz-grading",
  "version": "1.0.0",
  "description": "Multi-question-type grading engine: multi-choice, true-false, type-answer, fill-blank, numeric, matching with optional partial credit and speed bonus.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "quiz",
    "grading"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
