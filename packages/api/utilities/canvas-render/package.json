{
  "name": "@molecule/api-canvas-render",
  "version": "1.0.0",
  "description": "Server-side canvas rendering — render a canvas-document JSON into PNG/SVG/PDF buffers.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "canvas",
    "render",
    "png",
    "svg",
    "pdf"
  ],
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "1.0.0"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
