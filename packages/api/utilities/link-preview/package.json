{
  "name": "@molecule/api-link-preview",
  "version": "1.0.0",
  "description": "URL preview / OG-image scraper — extracts Open Graph, Twitter Card, and oEmbed metadata from a URL.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "link",
    "preview"
  ],
  "license": "MIT",
  "dependencies": {
    "undici": "7.28.0"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
