{
  "name": "@molecule/api-notifications-preferences",
  "version": "1.0.0",
  "description": "Per-user notification preferences (channel toggles per type) — single-row JSONB store with delivery-gate helpers.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "notifications",
    "preferences",
    "channels",
    "resource"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "25.8.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "@molecule/api-database": "^1.0.0",
    "@molecule/api-i18n": "^1.0.0",
    "@molecule/api-logger": "^1.0.0",
    "@molecule/api-resource": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@molecule/api-database": {
      "optional": true
    },
    "@molecule/api-i18n": {
      "optional": true
    },
    "@molecule/api-logger": {
      "optional": true
    },
    "@molecule/api-resource": {
      "optional": true
    }
  }
}
