{
  "name": "@molecule/api-resource-property",
  "version": "1.0.0",
  "description": "Property resource handlers (units, photos, amenities) with CRUD and soft-delete",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "property",
    "resource",
    "real-estate",
    "rental",
    "hotel"
  ],
  "license": "MIT",
  "devDependencies": {
    "@molecule/api-locales-property": "1.0.0",
    "@types/node": "25.8.0",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "@molecule/api-database": "^1.0.0",
    "@molecule/api-i18n": "^1.0.0",
    "@molecule/api-locales-property": "^1.0.0",
    "@molecule/api-logger": "^1.0.0",
    "@molecule/api-resource": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@molecule/api-resource": {
      "optional": true
    },
    "@molecule/api-database": {
      "optional": true
    },
    "@molecule/api-logger": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/molecule-dev/molecule.git",
    "directory": "packages/api/resources/property"
  },
  "homepage": "https://github.com/molecule-dev/molecule/tree/main/packages/api/resources/property",
  "bugs": "https://github.com/molecule-dev/molecule/issues",
  "publishConfig": {
    "access": "public"
  }
}
