{
  "name": "@molecule/api-resource-journal-entry",
  "version": "1.0.0",
  "description": "Owner-scoped journal entry resource with optional at-rest encryption, mood linkage, daily streaks, and JSON/CSV/TXT export. Extracted from mental-health-journal flagship.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "keywords": ["molecule", "journal", "diary", "mood", "encryption", "resource"],
  "license": "MIT",
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "express": "5.2.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@molecule/api-bonds-default-express": "^1.0.0",
    "@molecule/api-database": "^1.0.0",
    "@molecule/api-encryption": "^1.0.0",
    "@molecule/api-i18n": "^1.0.0",
    "@molecule/api-middleware-validation": "^1.0.0",
    "express": "^5.0.0",
    "zod": "^4.0.0"
  }
}
