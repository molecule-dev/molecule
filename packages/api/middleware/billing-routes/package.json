{
  "name": "@molecule/api-billing-routes",
  "version": "1.0.0",
  "description": "Drop-in /billing/* routes (checkout, cancel, portal) + defineTiers helper for molecule.dev",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "molecule",
    "billing",
    "routes",
    "stripe",
    "checkout",
    "portal"
  ],
  "author": "molecule.dev",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@molecule/api-bond": "^1.0.0",
    "@molecule/api-payments": "^1.0.0",
    "express": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@molecule/api-bond": "1.0.0",
    "@molecule/api-payments": "1.0.0",
    "@types/express": "5.0.6",
    "@types/node": "25.8.0",
    "express": "5.2.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/molecule-dev/molecule.git",
    "directory": "packages/api/middleware/billing-routes"
  },
  "homepage": "https://github.com/molecule-dev/molecule/tree/main/packages/api/middleware/billing-routes",
  "bugs": "https://github.com/molecule-dev/molecule/issues",
  "publishConfig": {
    "access": "public"
  }
}
