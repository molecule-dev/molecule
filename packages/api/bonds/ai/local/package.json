{
  "name": "@molecule/api-ai-local",
  "version": "1.0.0",
  "description": "AIProvider bond for any OpenAI-compatible local inference server (Ollama, LM Studio, llama.cpp, vLLM) — configurable base URL, keyless by default, streamed via raw fetch.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "ai",
    "local"
  ],
  "license": "MIT",
  "devDependencies": {
    "@molecule/api-ai": "1.0.0",
    "@molecule/api-bond": "1.0.0",
    "@molecule/api-secrets": "1.0.0",
    "@types/node": "25.9.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "@molecule/api-ai": "^1.0.0",
    "@molecule/api-bond": "^1.0.0",
    "@molecule/api-i18n": "^1.0.0",
    "@molecule/api-secrets": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@molecule/api-ai": {
      "optional": true
    }
  }
}
