{
  "name": "@molecule/api-channel-messenger",
  "version": "1.0.0",
  "description": "Facebook Messenger channel bond — implements @molecule/api-channel for sendMessage via the Send API, X-Hub-Signature-256 webhook verification, and inbound entry/messaging parsing.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "channel",
    "messenger"
  ],
  "license": "MIT",
  "devDependencies": {
    "@molecule/api-channel": "1.0.0",
    "@types/node": "25.5.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "@molecule/api-channel": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@molecule/api-channel": {
      "optional": true
    }
  }
}
