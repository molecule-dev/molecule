{
  "name": "@molecule/api-sitemap-xml",
  "version": "1.0.0",
  "description": "XML sitemap, RSS, and Atom feed provider for molecule.dev",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
