  ],
  "keywords": [
    "molecule",
    "sitemap",
    "xml",
    "rss",
    "atom",
    "feed"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@molecule/api-sitemap": "^1.0.0"
  },
  "devDependencies": {
    "@molecule/api-sitemap": "1.0.0",
    "@types/node": "25.5.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/molecule-dev/molecule.git",
    "directory": "packages/api/bonds/sitemap/xml"
  },
  "homepage": "https://github.com/molecule-dev/molecule/tree/main/packages/api/bonds/sitemap/xml",
  "bugs": "https://github.com/molecule-dev/molecule/issues",
  "publishConfig": {
    "access": "public"
  }
