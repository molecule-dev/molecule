{
  "name": "@molecule/api-pdf-pdfkit",
  "version": "1.0.0",
  "description": "PDFKit programmatic PDF generation provider for molecule.dev",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "pdf",
    "pdfkit",
    "generation",
    "programmatic"
  ],
  "license": "MIT",
  "dependencies": {
    "pdf-lib": "1.17.1",
    "pdfkit": "0.18.0"
  },
  "peerDependencies": {
    "@molecule/api-pdf": "^1.0.0"
  },
  "devDependencies": {
    "@molecule/api-pdf": "1.0.0",
    "@types/node": "25.5.0",
    "@types/pdfkit": "0.17.5",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/molecule-dev/molecule.git",
    "directory": "packages/api/bonds/pdf/pdfkit"
  },
  "homepage": "https://github.com/molecule-dev/molecule/tree/main/packages/api/bonds/pdf/pdfkit",
  "bugs": "https://github.com/molecule-dev/molecule/issues",
  "publishConfig": {
    "access": "public"
  }
}
