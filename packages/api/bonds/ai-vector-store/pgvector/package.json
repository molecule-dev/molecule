{
  "name": "@molecule/api-ai-vector-store-pgvector",
  "version": "1.0.0",
  "description": "PostgreSQL pgvector provider for molecule.dev — vector similarity search with pgvector",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
