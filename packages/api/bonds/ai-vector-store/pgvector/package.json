  },
  "peerDependencies": {
    "@molecule/api-ai-vector-store": ">=1.0.0"
  },
  "devDependencies": {
    "@molecule/api-ai-vector-store": "1.0.0",
    "@types/node": "25.5.0",
    "@types/pg": "8.15.4",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
