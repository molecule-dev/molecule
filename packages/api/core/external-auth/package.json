{
  "name": "@molecule/api-external-auth",
  "version": "1.0.0",
  "description": "External authentication interface for molecule.dev — verify user tokens issued by an imported app's own auth platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "external-auth",
    "auth",
    "jwt",
    "token"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@molecule/api-bond": "^1.0.0"
  },
  "devDependencies": {
    "@molecule/api-bond": "1.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/molecule-dev/molecule.git",
    "directory": "packages/api/core/external-auth"
  },
  "homepage": "https://github.com/molecule-dev/molecule/tree/main/packages/api/core/external-auth",
  "bugs": "https://github.com/molecule-dev/molecule/issues",
  "publishConfig": {
    "access": "public"
  }
}
