{
  "name": "@molecule/api-oauth-client",
  "version": "1.0.0",
  "description": "OAuth 2.0 client core interface for molecule.dev — consume external OAuth APIs with authorization, token exchange, refresh, and revocation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "oauth",
    "oauth2",
    "client",
    "authorization"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@molecule/api-bond": "^1.0.0",
    "@molecule/api-i18n": "^1.0.0"
  },
  "devDependencies": {
    "@molecule/api-bond": "1.0.0",
    "@molecule/api-i18n": "1.0.0",
    "@types/node": "25.5.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/molecule-dev/molecule.git",
    "directory": "packages/api/core/oauth-client"
  },
  "homepage": "https://github.com/molecule-dev/molecule/tree/main/packages/api/core/oauth-client",
  "bugs": "https://github.com/molecule-dev/molecule/issues",
  "publishConfig": {
    "access": "public"
  }
}
