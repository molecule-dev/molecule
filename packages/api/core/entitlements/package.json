{
  "name": "@molecule/api-entitlements",
  "version": "1.0.0",
  "description": "Tier-based entitlements core interface for molecule.dev: typed quantitative limits per subscription plan, plan-key cache, and tier-aware middleware factories",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "molecule",
    "entitlements",
    "tier",
    "subscription",
    "limits",
    "billing"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@molecule/api-bond": "^1.0.0",
    "@molecule/api-database": "^1.0.0",
    "@molecule/api-i18n": "^1.0.0",
    "@molecule/api-rate-limit": "^1.0.0"
  },
  "devDependencies": {
    "@molecule/api-bond": "1.0.0",
    "@molecule/api-database": "1.0.0",
    "@molecule/api-i18n": "1.0.0",
    "@molecule/api-payments": "1.0.0",
    "@molecule/api-payments-stripe": "1.0.0",
    "@molecule/api-rate-limit": "1.0.0",
    "@molecule/api-resource": "1.0.0",
    "@molecule/api-resource-user": "1.0.0",
    "@types/node": "25.5.0",
    "stripe": "20.3.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/molecule-dev/molecule.git",
    "directory": "packages/api/core/entitlements"
  },
  "homepage": "https://github.com/molecule-dev/molecule/tree/main/packages/api/core/entitlements",
  "bugs": "https://github.com/molecule-dev/molecule/issues",
  "publishConfig": {
    "access": "public"
  }
}
