#!/usr/bin/env bash
# Staged-only pre-commit hook. Original ran format:check + lint + tests over the
# entire monorepo (~30s), which serialised badly when many parallel agents were
# committing concurrently — the wide hook window let other agents' staged files
# bleed across commits. This version scopes format/lint to staged files and
# defers `npm test` to CI; lockfile + peer-deps checks remain.

set -e

# Fast secret scan — blocks a commit that introduces a high-confidence secret
# (staged added lines only). Runs first so a leaked key fails before the slower
# format/lint pass. Bypass a reviewed false positive with: git commit --no-verify
node scripts/precommit-secret-scan.mjs

STAGED=$(git diff --cached --name-only --diff-filter=AM)
if [ -z "$STAGED" ]; then
  exit 0
fi

JSTS=$(echo "$STAGED" | grep -E '\.(ts|tsx|js|jsx|mjs|cjs)$' || true)
JSON_MD=$(echo "$STAGED" | grep -E '\.(json|md|css|scss|html|yaml|yml)$' || true)

if [ -n "$JSTS" ]; then
  echo "$JSTS" | xargs npx --no-install prettier --check
  echo "$JSTS" | xargs npx --no-install eslint --no-error-on-unmatched-pattern
fi

if [ -n "$JSON_MD" ]; then
  echo "$JSON_MD" | xargs npx --no-install prettier --check
fi

npm run check:lockfile
npm run check:peer-deps
# i18n parity (cross-cutting-i18n) — full-tree scan, but fast (~0.1s) and it
# only fails on NEW missing keys vs the baseline, so a string shipped as an
# inline defaultValue without its bond key is caught here at commit time, not
# weeks later. (Whole-tree, not staged-only: a key added in package A must be
# checked against its owning locale bond in package B.)
npm run check:i18n-parity

# Registry export-drift gate (same spirit as i18n-parity, but cross-REPO). A
# package's public exports are the source of truth, yet they are recorded in
# mlcl/registry.json — a SEPARATE repo whose CI never checks this one out, so a
# changed export drifts the registry silently until a manual sync (that is how
# 815 packages' exports went stale once). Catch it here, at the commit that
# changes the exports, scoped to only the staged packages so it stays fast under
# parallel agents. Runs the check via tsx against mlcl SOURCE (no build needed —
# the scanner subgraph imports no @molecule/* packages). Skips (does not block)
# when mlcl is a non-sibling or its deps aren't installed — e.g. a standalone
# molecule clone — where the registry simply isn't reachable.
PKG_SRC=$(echo "$STAGED" | grep -E '^packages/.+/src/' || true)
if [ -n "$PKG_SRC" ]; then
  PKG_DIRS=$(echo "$PKG_SRC" | while IFS= read -r f; do echo "${f%%/src/*}"; done | sort -u)
  if [ -x ../mlcl/node_modules/.bin/tsx ]; then
    ( cd ../mlcl && node_modules/.bin/tsx scripts/check-registry-exports.mjs $PKG_DIRS )
  else
    echo "ℹ registry-export check skipped: mlcl deps not installed — run 'npm ci' in mlcl, then 'npm run verify:registry-exports' to verify"
  fi
fi
